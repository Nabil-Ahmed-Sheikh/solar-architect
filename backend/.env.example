# Backend environment variables
# Copy this file to .env and fill in the values.

# Django secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-long-random-string

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Google Maps API key — optional, enables satellite map view
# If omitted the map falls back to a static SVG placeholder
GOOGLE_MAPS_API_KEY=

# Redis URL — optional, required for async LiDAR processing via Celery
# Defaults to this value if not set
REDIS_URL=redis://localhost:6379/0

# PostgreSQL connection string — optional, defaults to SQLite when blank
# Example: postgres://user:password@localhost:5432/solararchitect
DATABASE_URL=
